// =============================================================================
// Exposure Engine — INDICATOR  (Pine Script v6)
// -----------------------------------------------------------------------------
// Direct translation of the StockOdds C# engine. The C# is the source of truth:
//   * CandleType classification  (LongTermStateEngine.GetCandleType)
//   * LongTermStateEngine        (anchor-based LT state machine)
//   * CandleStateEngine          (ShortTermState 4-state machine)
//   * BankrollSimulator exposure (per-candle (LT,ST) target -> EMA -> drift band -> clamp)
//
// The engine section below is byte-for-byte identical to the one in
// ExposureEngine_Strategy.pine so the strategy runs the *exact same* engine.
//
// Per-bar mapping to the C# loop (Program.cs / BankrollSimulator.Run):
//   C# calls Update(bars[i-2], bars[i-1]) => the state is evaluated with
//   `current = bars[i-1]` and `prev = bars[i-2]`, i.e. candle type comes from
//   current.Close vs prev.High/prev.Low. In Pine, on the current bar:
//       current = bar[0], prev = bar[1]  =>  candle = f(close, high[1], low[1])
//   So the state Pine shows on bar t equals the C# state attributed to the
//   transition bar bars[i-1]. This is the same object, stepped one bar at a time.
// =============================================================================

//@version=6
// overlay = false: this script owns a separate pane where the exposure / EMA lines
// are drawn on their own -1..+1 scale. The price-chart visuals (candle coloring, LT
// background, anchors) are pushed back onto the main chart with force_overlay = true.
indicator("Exposure Engine [Indicator]", overlay = false, max_labels_count = 500)

// =============================================================================
// 0. INPUTS
// =============================================================================
grpUI   = "Display"
showBackground = input.bool(true,  "Show background (LT regime)", group = grpUI)
showTable      = input.bool(true,  "Show table (top-right)",      group = grpUI)
showDebug      = input.bool(false, "Show debug information",      group = grpUI)
showAnchors    = input.bool(false, "Show anchors",                group = grpUI)

grpExp = "Exposure pane"
showExposure = input.bool(true,  "Show exposure (position) line",  group = grpExp)
showEma      = input.bool(true,  "Show exposure EMA line",         group = grpExp)
showBand     = input.bool(false, "Show rebalance band (EMA ± drift)", group = grpExp)
showStValue  = input.bool(false, "Show ST-value stepline",         group = grpExp)
showGuides   = input.bool(false, "Show 0 / ±0.5 / ±1 guide lines", group = grpExp)

grpColor = "Candle colors"
colBull      = input.color(#00E676, "Bull (bright green)",  group = grpColor)
colBullN     = input.color(#A5D6A7, "Bull Neutral (light green)", group = grpColor)
colBearN     = input.color(#FF9800, "Bear Neutral (orange)", group = grpColor)
colBear      = input.color(#F23645, "Bear (red)",           group = grpColor)
colBgBull    = input.color(color.new(#26A69A, 88), "Background LT Bull", group = grpColor)
colBgBear    = input.color(color.new(#F23645, 88), "Background LT Bear", group = grpColor)

// -- Exposure model: one target per (LT, ST) bucket. Long positive, short negative.
grpBull = "Exposure — LT Bull (per ST state)"
bullBear  = input.float(-0.50, "ST Bear",         step = 0.05, group = grpBull)
bullBearN = input.float( 0.00, "ST Bear Neutral", step = 0.05, group = grpBull)
bullBullN = input.float( 0.50, "ST Bull Neutral", step = 0.05, group = grpBull)
bullBull  = input.float( 1.00, "ST Bull",         step = 0.05, group = grpBull)

grpBear = "Exposure — LT Bear (per ST state)"
bearBull  = input.float( 0.50, "ST Bull",         step = 0.05, group = grpBear)
bearBullN = input.float( 0.00, "ST Bull Neutral", step = 0.05, group = grpBear)
bearBearN = input.float(-0.50, "ST Bear Neutral", step = 0.05, group = grpBear)
bearBear  = input.float(-1.00, "ST Bear",         step = 0.05, group = grpBear)

// -- Smoothing & rebalance control
grpSmooth = "Smoothing & rebalance"
emaPeriod = input.int(5, "Exposure EMA period", minval = 1, group = grpSmooth,
     tooltip = "The per-candle target exposure is smoothed by this EMA before it is traded.")
biasPeriod = input.int(15, "Bias period", minval = 1, group = grpSmooth,
     tooltip = "Look-back for the dynamic long bias. The LT direction (+1 Bull, -1 Bear) is summed over this many candles. A window evenly split Bull/Bear gives 0; all-Bull gives +1, all-Bear -1.")
biasEmaPeriod = input.int(150, "Bias EMA period", minval = 1, group = grpSmooth,
     tooltip = "The dynamic bias is smoothed by this EMA before it skews the exposure EMA.")
driftPct  = input.float(30, "Rebalance drift (%)", minval = 0, step = 1, group = grpSmooth,
     tooltip = "Only move the position when it has drifted more than this many exposure-% from the EMA, then snap it back to the EMA. e.g. 20 with EMA 0.50 -> rebalance only if position < 0.30 or > 0.70. The 'Target' row shows this band: EMA ± drift.")
minExpPct = input.float(0, "Min exposure (%)", minval = -100, maxval = 100, step = 5, group = grpSmooth,
     tooltip = "Clamp on the POSITION only (not the per-candle target). -100 = fully short.")
maxExpPct = input.float(100,  "Max exposure (%)", minval = -100, maxval = 100, step = 5, group = grpSmooth,
     tooltip = "Clamp on the POSITION only (not the per-candle target). 100 = fully long.")

// -- Dynamic (per-candle) long bias: scale LongBias by z = z(HV) + z(persistence)
grpDyn = "Dynamic long bias"
showDynLB = input.bool(false, "Plot dynamic long bias line", group = grpDyn,
     tooltip = "Plots the per-candle LongBias. It is on a 0..max scale, not -1..1, so it rescales this pane — turn off the exposure/EMA lines to view it cleanly. It is always in the Data Window and the table regardless.")
dynBase  = input.float(1.0,  "LongBias at z = 0 (Base)", step = 0.5, group = grpDyn)
dynDecay = input.float(0.6,  "Exp decay (Exponential only)", step = 0.05, group = grpDyn)
dynMin   = input.float(0.0,  "LongBias min", step = 0.5, group = grpDyn)
dynMax   = input.float(150.0, "LongBias max", step = 0.5, group = grpDyn)
dynSmooth = input.int(10, "Bias smoothing (EMA bars)", minval = 1, group = grpDyn,
     tooltip = "EMA-smooth the per-candle LongBias so it does not whipsaw. 1 = off.")
biasSplit    = input.bool(true, "Split bias across LT dirs", group = grpDyn,
     tooltip = "Rolling sum: a Bull candle contributes 1 + bias/2 and a Bear candle -1 + bias/2 (instead of 1+bias / -1). The bias becomes a long tilt on BOTH sides, so a high-bias choppy name keeps conviction elevated through its LT-Bear stretches (a cleaner hold-through-chop). Broad-validated: Sharpe up in every HV bucket, edges buy&hold, ~flat drawdown. On by default.")
hvWindow      = input.int(60, "HV window (bars)", minval = 2, group = grpDyn)
persistWindow = input.int(63, "Persistence window (bars)", minval = 2, group = grpDyn)
hvRefMean   = input.float(57.0,   "HV ref mean",          group = grpDyn, tooltip = "Fixed reference for z-scoring rolling HV.")
hvRefStd    = input.float(34.6,   "HV ref std",           group = grpDyn)
persRefMean = input.float(0.072, "Persistence ref mean", group = grpDyn)
persRefStd  = input.float(0.010, "Persistence ref std",  group = grpDyn)

// -- Out-of-region rule (mirrors BankrollSimulator.BearRegimeMode)
grpRegime = "Out-of-region rule"
bearRegimeMode = input.string("Cash", "Out-of-region mode", options = ["Cash", "Hold (buy & hold)", "Deploy strategy"], group = grpRegime,
     tooltip = "When the raw exposure signal is bearish -- the EMA of the (LT,ST) target exposure (before the bias skew) is < 0: Cash = flatten to 0 (default — rotate capital to an in-region name); Hold = force exposure 1 (mirror buy & hold); Deploy = keep running the strategy.")

grpRsi = "RSI position overlay"
rsiOverlayPeriod = input.int(2, "RSI overlay period (0 = off)", minval = 0, group = grpRsi,
     tooltip = "Overbought-trim overlay on the final position: position *= min(N / RSI(period), 1), N = numerator below — trims when overbought; does nothing when oversold (capped at 1, never levers up). 0 disables. Short period (2) validated best across four random-500 OOS samples; an ablation showed the trim is the entire edge, so it never levers.")
rsiMultNumerator = input.float(15, "RSI mult numerator N (out-of-region / shaping off)", minval = 1, group = grpRsi,
     tooltip = "Numerator N in min(N/RSI, 1): the overbought threshold AND trim depth (trim begins when RSI>N; at RSI=100 exposure -> N%). Used out-of-region (Deploy's ema<0 bars) and whenever exposure shaping is off. A LOW N (default 15, was 50) beats 50 on Sharpe AND drawdown across four random-500 OOS samples -- a deeper, earlier mean-reversion trim (more defensive). CAVEAT: leans on the mean-reverting 2023-26 test window; would under-participate in a sustained momentum regime.")
rsiExposureMult = input.float(0, "RSI exposure shaping mult (0 = fixed N, default)", minval = 0, group = grpRsi,
     tooltip = "OPT-IN, OFF by default. IN-REGION, scale the trim by how exposed the position is: N = clamp((1 - ema) * this, 1, 100). Near-full-long (ema->1) => N->1 (fade overbought hard); lightly long (ema->0) => N->this. It reduces the drawdown TAIL but trims return in ~proportion to drawdown (Calmar-flat, and it costs the Hold benchmark), so the shipped default is the fixed numerator above. Set to 20 (the OOS-optimal mult) to enable exposure shaping.")

// #############################################################################
// ############   SHARED ENGINE  (identical in indicator & strategy)   #########
// #############################################################################

// -----------------------------------------------------------------------------
// 1. CANDLE CLASSIFICATION  (LongTermStateEngine.GetCandleType)
//    return codes:  1 = Bull, -1 = Bear, 0 = Neutral
//        Bull  : current.Close > prev.High
//        Bear  : current.Close < prev.Low
//        else  : Neutral
// -----------------------------------------------------------------------------
f_classify(cl, prevHigh, prevLow) =>
    na(prevHigh) or na(prevLow) ? 0 : cl > prevHigh ? 1 : cl < prevLow ? -1 : 0

// -----------------------------------------------------------------------------
// 2. LONG TERM ENGINE  (LongTermStateEngine.Update)
//    LT state codes: 1 = Bull, 0 = Bear  (initial = Bear, matching C#)
//    Anchors trail the sequence (2nd-to-last candle). Neutral candles do
//    nothing except preserve the running sequences — exactly as in C#.
//    Returns: [state, bullCount, bearCount, bullAnchor, bearAnchor]
// -----------------------------------------------------------------------------
f_ltUpdate(candle, hi, lo, cl) =>
    var int   bullCount    = 0
    var int   bearCount    = 0
    var float bullAnchor   = na
    var float bearAnchor   = na
    var float lastBullLow  = na
    var float lastBearHigh = na
    var int   state        = 0            // 0 = Bear (LongTermState.Bear)

    if candle == 1
        // ---- BULL CANDLE ----
        bearCount := 0
        bullCount += 1
        // prior "last" bull low becomes the 2nd-to-last -> new anchor
        if bullCount >= 2
            bullAnchor := lastBullLow
        lastBullLow := lo
        // confirmation: transition to LT Bull
        if bullCount >= 2 and not na(bearAnchor) and cl > bearAnchor
            state := 1
    else if candle == -1
        // ---- BEAR CANDLE ----
        bullCount := 0
        bearCount += 1
        if bearCount >= 2
            bearAnchor := lastBearHigh
        lastBearHigh := hi
        // exit / bearish transition to LT Bear
        if bearCount >= 2 and not na(bullAnchor) and cl < bullAnchor
            state := 0
    // else NEUTRAL: preserve sequences, do nothing

    [state, bullCount, bearCount, bullAnchor, bearAnchor]

// -----------------------------------------------------------------------------
// 3. SHORT TERM ENGINE  (CandleStateEngine.Update)
//    ST state codes chosen to equal the C# bullishness rank:
//        3 = Bull, 2 = BullNeutral, 1 = BearNeutral, 0 = Bear, na = null
//    Neutral candles do not affect counts or state.
//    Returns: [st, bullCount, bearCount]
// -----------------------------------------------------------------------------
f_stUpdate(candle) =>
    var int bullCount = 0
    var int bearCount = 0
    var int st        = na                // ShortTermState? currentState = null

    if candle == 1
        bullCount += 1
        bearCount := 0
        if bullCount >= 2
            st := 3                        // Bull
        else if st == 0                    // first Bull after a Bear sequence
            st := 1                        // BearNeutral
    else if candle == -1
        bearCount += 1
        bullCount := 0
        if bearCount >= 2
            st := 0                        // Bear
        else if st == 3                    // first Bear after a Bull sequence
            st := 2                        // BullNeutral
    // else NEUTRAL: no change

    [st, bullCount, bearCount]

// -----------------------------------------------------------------------------
// 4. TARGET EXPOSURE  (BankrollSimulator.TargetExposure)
//    One value per (LT, ST) bucket; already signed (short negative).
//    ST codes: 3=Bull 2=BullNeutral 1=BearNeutral 0=Bear
// -----------------------------------------------------------------------------
f_target(lt, st) =>
    na(lt) or na(st) ? na :
     lt == 1 ?
       (st == 3 ? bullBull : st == 2 ? bullBullN : st == 1 ? bullBearN : bullBear) :
       (st == 3 ? bearBull : st == 2 ? bearBullN : st == 1 ? bearBearN : bearBear)

// #############################################################################
// ############   END SHARED ENGINE                                    #########
// #############################################################################

// =============================================================================
// 5. RUN THE ENGINE ON THIS BAR
// =============================================================================
candle = f_classify(close, high[1], low[1])

[ltState, ltBullCount, ltBearCount, bullAnchor, bearAnchor] = f_ltUpdate(candle, high, low, close)
[stState, stBullCount, stBearCount]                         = f_stUpdate(candle)

target = f_target(ltState, stState)

// -----------------------------------------------------------------------------
// 5b. SMOOTH + REBALANCE
//     emaExp   : EMA of the per-candle target (same recurrence as the C# sim)
//     adjEma   : dynamic long-bias skew of the EMA  ->  |emaExp|*dynBiasEma + emaExp
//     held     : follows adjEma, but only re-sets when it drifts past the band
//     position : held, clamped to [min, max] — the exposure actually reported/traded
// -----------------------------------------------------------------------------
alpha = 2.0 / (emaPeriod + 1)
var float emaExp = na
if not na(target)
    emaExp := na(emaExp) ? target : alpha * target + (1 - alpha) * emaExp

// Per-candle LongBias: fixed, or scaled by z = z(HV) + z(persistence). z uses FIXED
// reference constants (absolute scale): quiet name (z<0) -> large bias, hot name (z>0)
// -> small bias. Mirrors BankrollSimulator's DynamicLongBias.
hvRet  = na(close[1]) or close[1] <= 0 or close <= 0 ? na : math.log(close / close[1])
rollHv = ta.stdev(hvRet, hvWindow, false) * math.sqrt(252) * 100
zHv    = not na(rollHv) and hvRefStd > 0 ? (rollHv - hvRefMean) / hvRefStd : 0.0
// persistence = Kaufman efficiency ratio of the pre-bias exposure EMA over persistWindow
netMove = math.abs(target - target[persistWindow])
pathLen = math.sum(math.abs(target - target[1]), persistWindow)
er      = pathLen > 1e-9 ? math.min(1.0, netMove / pathLen) : 1.0
zP      = not na(target[persistWindow]) and persRefStd > 0 ? (er - persRefMean) / persRefStd : 0.0
zTrait  = zHv + zP
dynLBraw = dynBase * math.exp(-dynDecay * zTrait)
dynLBc  = math.min(math.max(dynLBraw, dynMin), dynMax)
var float dynLbEma = na
dynLbEma := na(dynLbEma) ? dynLBc : (2.0 / (dynSmooth + 1)) * dynLBc + (1 - 2.0 / (dynSmooth + 1)) * dynLbEma
effLongBias = math.max(dynLbEma, dynMin)

// Dynamic long bias: rolling LT-direction sum over biasPeriod / biasPeriod.
// A Bull candle contributes (effLongBias + 1), a Bear candle -1; effLongBias skews
// the Bull weight (0 -> +1, -0.5 -> +0.5, +1 -> +2).
biasSig = biasSplit ? (ltState == 1 ? (1 + effLongBias / 2) : ltState == 0 ? (-1 + effLongBias / 2) : 0) : (ltState == 1 ? (effLongBias + 1) : ltState == 0 ? -1 : 0)
// C#-faithful sliding sum: add the current signal, drop the one leaving the window,
// divide by biasPeriod ALWAYS (partial early) — valid from bar 1, mirroring the C# Queue.
var float biasSum = 0.0
biasSum += biasSig
if bar_index >= biasPeriod
    biasSum -= biasSig[biasPeriod]
dynBias = biasSum / biasPeriod
// C#-faithful EMA seeded on the first bar. (ta.ema warms up ~biasEmaPeriod bars, leaving
// `position` na and the whole strategy dormant until then — with period 200 that skipped
// ~200 bars, re-anchoring the buy&hold and hiding the crash-protection window. C# seeds
// immediately, so we replicate that here.)
biasAlpha = 2.0 / (biasEmaPeriod + 1)
var float dynBiasEma = na
dynBiasEma := na(dynBiasEma) ? dynBias : biasAlpha * dynBias + (1 - biasAlpha) * dynBiasEma
// long-bias skew of the EMA: adjEma = |ema| * biasEma + ema  (mirrors C# BankrollSimulator)
adjEma = na(emaExp) ? na : math.abs(emaExp) * dynBiasEma + emaExp

driftBand = driftPct / 100.0
var float held = na
// Normal drift-band rebalance.
if not na(adjEma) and (na(held) or math.abs(held - adjEma) > driftBand)
    held := adjEma

loExp = math.min(minExpPct, maxExpPct) / 100.0
hiExp = math.max(minExpPct, maxExpPct) / 100.0
posClamped = na(held) ? na : math.min(math.max(held, loExp), hiExp)
// RSI overbought-trim overlay on the in-region position: *= min(N/RSI, 1) (trim when overbought only, never levers), before the out-of-region rule.
// N is exposure-shaped in-region: N = clamp((1 - emaExp) * rsiExposureMult, 1, 100) -- trim harder the more exposed you are; out-of-region it stays fixed at rsiMultNumerator.
rsiVal = ta.rsi(close, math.max(rsiOverlayPeriod, 1))
rsiNumer = (rsiExposureMult > 0 and not na(emaExp) and emaExp >= 0) ? math.min(math.max((1 - emaExp) * rsiExposureMult, 1.0), 100.0) : rsiMultNumerator
rsiPos = (rsiOverlayPeriod > 0 and not na(posClamped) and not na(rsiVal) and rsiVal > 0) ? math.min(math.max(posClamped * math.min(rsiNumer / rsiVal, 1.0), loExp), hiExp) : posClamped

// OUT-OF-REGION rule (mirrors BankrollSimulator.BearRegimeMode): out of region when the RAW exposure signal is
// bearish -- the EMA of the (LT,ST) target (emaExp, before the bias skew) is < 0. Parameter-free.
// regimeMode: 1 = Cash (flat), 2 = Hold (full long), 0 = Deploy (keep strategy).
regimeMode  = bearRegimeMode == "Cash" ? 1 : bearRegimeMode == "Hold (buy & hold)" ? 2 : 0
inRegion    = na(emaExp) or emaExp >= 0
outOfRegion = regimeMode != 0 and not na(emaExp) and emaExp < 0
position = na(posClamped) ? na : (outOfRegion ? (regimeMode == 1 ? 0.0 : 1.0) : rsiPos)

// =============================================================================
// 6. NAME HELPERS
// =============================================================================
f_ltName(lt)     => na(lt) ? "—" : lt == 1 ? "Bull" : "Bear"
f_stName(st)     => na(st) ? "—" : st == 3 ? "Bull" : st == 2 ? "Bull Neutral" : st == 1 ? "Bear Neutral" : "Bear"
f_candleName(c)  => c == 1 ? "Bull" : c == -1 ? "Bear" : "Neutral"

// =============================================================================
// 7. UI — CANDLE COLORING (by ST state)
// =============================================================================
barCol = na(stState) ? na :
         stState == 3 ? colBull :
         stState == 2 ? colBullN :
         stState == 1 ? colBearN : colBear
barcolor(barCol)   // barcolor always colors the main chart bars (no force_overlay needed)

// =============================================================================
// 8. UI — BACKGROUND (by LT regime)  [forced onto the price chart]
// =============================================================================
bg = ltState == 1 ? colBgBull : colBgBear
bgcolor(showBackground ? bg : na, title = "LT regime", force_overlay = true)

// =============================================================================
// 9. UI — ANCHORS  [forced onto the price chart]
// =============================================================================
plot(showAnchors ? bullAnchor : na, "Bull Anchor", color = color.new(#26A69A, 0), style = plot.style_circles, linewidth = 2, force_overlay = true)
plot(showAnchors ? bearAnchor : na, "Bear Anchor", color = color.new(#F23645, 0), style = plot.style_circles, linewidth = 2, force_overlay = true)

// =============================================================================
// 9b. EXPOSURE PANE — the -1..+1 exposure series (this indicator's own pane).
//     Target = raw (LT,ST) map value; EMA = smoothed target; Exposure = the
//     drift-banded, clamped position actually applied. Green above 0 (long),
//     red below 0 (short).
// =============================================================================
gcol0 = color.new(color.gray, showGuides ? 0  : 100)
gcol1 = color.new(color.gray, showGuides ? 55 : 100)
gcol2 = color.new(color.gray, showGuides ? 80 : 100)
hline( 0.0, "Zero",      color = gcol0, linestyle = hline.style_solid)
hline( 1.0, "Max long",  color = gcol1, linestyle = hline.style_dotted)
hline(-1.0, "Max short", color = gcol1, linestyle = hline.style_dotted)
hline( 0.5, "+0.5",      color = gcol2, linestyle = hline.style_dotted)
hline(-0.5, "-0.5",      color = gcol2, linestyle = hline.style_dotted)

// raw (LT,ST) map value that feeds the EMA
plot(showStValue ? target : na, "ST value", color = color.new(color.gray, 30), style = plot.style_stepline)

// rebalance band: adjEma ± drift — the zone the position holds inside without rebalancing
bandUp = na(adjEma) ? na : adjEma + driftBand
bandDn = na(adjEma) ? na : adjEma - driftBand
pUp = plot(showBand ? bandUp : na, "Target band +", color = color.new(#2962FF, 55), linewidth = 1)
pDn = plot(showBand ? bandDn : na, "Target band -", color = color.new(#2962FF, 55), linewidth = 1)
fill(pUp, pDn, color = color.new(#2962FF, 90), title = "Rebalance band")

// raw EMA (faint) vs long-bias-adjusted EMA (bold, the one that drives the position)
plot(showEma ? emaExp : na, "EMA (raw)",      color = color.new(#2962FF, 65), linewidth = 1)
plot(showEma ? adjEma : na, "EMA (adj bias)", color = #2962FF, linewidth = 2)

// per-candle dynamic long bias (own 0..max scale — rescales the pane when shown)
plot(showDynLB ? effLongBias : na, "Dyn LongBias", color = #FF6D00, linewidth = 2, style = plot.style_stepline)

bgcolor(outOfRegion ? color.new(color.gray, 82) : na, title = "Out-of-region (cash/hold)")
posColor = na(position) ? na : position >= 0 ? colBull : colBear
pPos = plot(showExposure ? position : na, "Exposure (position)", color = posColor, linewidth = 2, style = plot.style_stepline)
pZero = plot(showExposure ? 0.0 : na, "", color = na, display = display.none)
fill(pPos, pZero, color = na(position) ? na : color.new(posColor, 82), title = "Exposure fill")

// =============================================================================
// 10. UI — TABLE (top-right)
// =============================================================================
var table tbl = table.new(position.top_right, 2, 12, border_width = 1, frame_width = 1, frame_color = color.gray, force_overlay = true)

f_row(row, k, v, txtCol) =>
    table.cell(tbl, 0, row, k, text_color = color.gray,  text_halign = text.align_left,  text_size = size.small, bgcolor = color.new(color.black, 70))
    table.cell(tbl, 1, row, v, text_color = txtCol,      text_halign = text.align_right, text_size = size.small, bgcolor = color.new(color.black, 70))

if showTable and barstate.islast
    ltCol = ltState == 1 ? colBull : colBear
    stCol = na(stState) ? color.gray : stState == 3 ? colBull : stState == 2 ? colBullN : stState == 1 ? colBearN : colBear
    posCol = na(position) ? color.gray : position >= 0 ? colBull : colBear
    // Exposure = the actual traded (post-RSI) position ± rebalance drift, clamped. Out of region the rule
    // forces a single value (0 cash / 1 hold), so show that alone — no rebalance drift there.
    expLo = str.tostring(math.min(math.max(position - driftBand, loExp), hiExp), "#.##")
    expHi = str.tostring(math.min(math.max(position + driftBand, loExp), hiExp), "#.##")
    expTxt = na(position) ? "—" : outOfRegion ? str.tostring(position, "#.##") : expLo + " – " + expHi
    f_row(0,  "LT State",    f_ltName(ltState), ltCol)
    f_row(1,  "ST State",    f_stName(stState), stCol)
    f_row(2,  "ST Value",    na(target)   ? "—" : str.tostring(target, "#.##"),  stCol)
    f_row(3,  "EMA",         na(emaExp)   ? "—" : str.tostring(emaExp, "#.##"),  color.white)
    f_row(4,  "Adj EMA",     na(adjEma)   ? "—" : str.tostring(adjEma, "#.##"),  color.white)
    f_row(5,  "Exposure",    expTxt, posCol)
    f_row(6,  "Bull Count",  str.tostring(ltBullCount), color.white)
    f_row(7,  "Bear Count",  str.tostring(ltBearCount), color.white)
    f_row(8,  "Anchors B/S", (na(bullAnchor) ? "—" : str.tostring(bullAnchor, format.mintick)) + " / " + (na(bearAnchor) ? "—" : str.tostring(bearAnchor, format.mintick)), color.white)
    f_row(9,  "Candle Type", f_candleName(candle), candle == 1 ? colBull : candle == -1 ? colBear : color.gray)
    f_row(10, "Dyn LongBias", str.tostring(effLongBias, "#.##") + "  (z " + str.tostring(zTrait, "#.##") + ")", #FF6D00)
    regionTxt = inRegion ? "IN region" : (regimeMode == 1 ? "OUT -> cash" : regimeMode == 2 ? "OUT -> hold" : "OUT (deploy)")
    regionCol = inRegion ? colBull : colBear
    f_row(11, "Region", regionTxt, regionCol)

// =============================================================================
// 11. DEBUG — bar-by-bar values for comparison against the C# engine.
//     Values are exposed in the Data Window (hover any bar) when Debug is on.
//     ST/LT plotted as their integer codes:  LT 1=Bull 0=Bear ;
//     ST 3=Bull 2=BullNeutral 1=BearNeutral 0=Bear ; Candle 1/-1/0.
// =============================================================================
plot(showDebug ? ltBullCount : na, "DBG Bull Count",  display = display.data_window)
plot(showDebug ? ltBearCount : na, "DBG Bear Count",  display = display.data_window)
plot(showDebug ? bullAnchor  : na, "DBG Bull Anchor", display = display.data_window)
plot(showDebug ? bearAnchor  : na, "DBG Bear Anchor", display = display.data_window)
plot(showDebug ? candle      : na, "DBG Candle Type", display = display.data_window)
plot(showDebug ? ltState     : na, "DBG LT State",    display = display.data_window)
plot(showDebug ? stState     : na, "DBG ST State",    display = display.data_window)
plot(showDebug ? target      : na, "DBG ST Value",  display = display.data_window)
plot(showDebug ? emaExp      : na, "DBG EMA",       display = display.data_window)
plot(showDebug ? dynBias     : na, "DBG Dyn Bias",  display = display.data_window)
plot(showDebug ? dynBiasEma  : na, "DBG Dyn Bias EMA", display = display.data_window)
plot(effLongBias, "DBG Dyn LongBias", display = display.data_window)
plot(zTrait, "DBG z (HV+persist)", display = display.data_window)
plot(showDebug ? adjEma      : na, "DBG Adj EMA",   display = display.data_window)
plot(showDebug ? position    : na, "DBG Exposure",  display = display.data_window)
