// =============================================================================
// Exposure Engine — INDICATOR  (Pine Script v6)
// -----------------------------------------------------------------------------
// Direct translation of the StockOdds C# engine. The C# is the source of truth:
//   * CandleType classification        (LongTermStateEngine.GetCandleType)
//   * LongTermStateEngine              (anchor-based LT state machine)
//   * CandleStateEngine                (ShortTermState 4-state machine)
//   * BankrollSimulator exposure logic (long & short ramp-in, MIN st-cap; short = inverse of long)
//
// The engine section below is byte-for-byte identical to the one in
// ExposureEngine_Strategy.pine so the strategy runs the *exact same* engine.
//
// Per-bar mapping to the C# loop (Program.cs / BankrollSimulator.Run):
//   C# calls Update(bars[i-2], bars[i-1]) => the state is evaluated with
//   `current = bars[i-1]` and `prev = bars[i-2]`, i.e. candle type comes from
//   current.Close vs prev.High/prev.Low. In Pine, on the current bar:
//       current = bar[0], prev = bar[1]  =>  candle = f(close, high[1], low[1])
//   So the state Pine shows on bar t equals the C# state attributed to the
//   transition bar bars[i-1]. This is the same object, stepped one bar at a time.
// =============================================================================

//@version=6
indicator("Exposure Engine [Indicator]", overlay = true, max_labels_count = 500)

// =============================================================================
// 0. INPUTS
// =============================================================================
grpUI   = "Display"
showBackground = input.bool(true,  "Show background (LT regime)", group = grpUI)
showTable      = input.bool(true,  "Show table (top-right)",      group = grpUI)
showDebug      = input.bool(false, "Show debug information",      group = grpUI)
showAnchors    = input.bool(false, "Show anchors",                group = grpUI)

grpColor = "Candle colors"
colBull      = input.color(#00E676, "Bull (bright green)",  group = grpColor)
colBullN     = input.color(#A5D6A7, "Bull Neutral (light green)", group = grpColor)
colBearN     = input.color(#FF9800, "Bear Neutral (orange)", group = grpColor)
colBear      = input.color(#F23645, "Bear (red)",           group = grpColor)
colBgBull    = input.color(color.new(#26A69A, 88), "Background LT Bull", group = grpColor)
colBgBear    = input.color(color.new(#F23645, 88), "Background LT Bear", group = grpColor)

grpModel = "Exposure model"
MODEL_FAITHFUL = "C# Ramp/Cap (faithful)"
MODEL_SIMPLE   = "Simple Bucket Mapping"
exposureModel  = input.string(MODEL_FAITHFUL, "Exposure model",
     options = [MODEL_FAITHFUL, MODEL_SIMPLE], group = grpModel,
     tooltip = "Faithful = mirrors BankrollSimulator (long & short ramp-in, MIN ST-cap; short is the inverse of long).\nSimple = single configurable target per (LT,ST) bucket (the prompt's mapping table).")

// -- Faithful (BankrollSimulator) knobs ---------------------------------------
grpRamp = "Faithful: Long ramp-in levels (LongRampLevels)"
rampL0 = input.float(0.25, "Rung 0 (entry)", step = 0.05, group = grpRamp)
rampL1 = input.float(0.50, "Rung 1",         step = 0.05, group = grpRamp)
rampL2 = input.float(0.75, "Rung 2",         step = 0.05, group = grpRamp)
rampL3 = input.float(1.00, "Rung 3 (top)",   step = 0.05, group = grpRamp)

grpCapBull = "Faithful: ST exposure caps — LONG (by aligned rank)"
stCapBull0 = input.float(0.25, "ST Bear (least aligned)",     step = 0.05, group = grpCapBull)
stCapBull1 = input.float(0.50, "ST Bear Neutral",            step = 0.05, group = grpCapBull)
stCapBull2 = input.float(0.75, "ST Bull Neutral",            step = 0.05, group = grpCapBull)
stCapBull3 = input.float(1.00, "ST Bull (fully aligned)",     step = 0.05, group = grpCapBull)

grpCapBear = "Faithful: ST exposure caps — SHORT (negative; by aligned rank)"
stCapBear0 = input.float(-0.25, "ST Bull (least aligned)",    step = 0.05, group = grpCapBear)
stCapBear1 = input.float(-0.50, "ST Bull Neutral",           step = 0.05, group = grpCapBear)
stCapBear2 = input.float(-0.75, "ST Bear Neutral",           step = 0.05, group = grpCapBear)
stCapBear3 = input.float(-1.00, "ST Bear (fully aligned)",    step = 0.05, group = grpCapBear)

grpShortRamp = "Faithful: Short ramp-in levels (ShortRampLevels) — inverse of long"
sRampL0 = input.float(0.25, "Rung 0 (entry)", step = 0.05, group = grpShortRamp)
sRampL1 = input.float(0.50, "Rung 1",         step = 0.05, group = grpShortRamp)
sRampL2 = input.float(0.75, "Rung 2",         step = 0.05, group = grpShortRamp)
sRampL3 = input.float(1.00, "Rung 3 (top)",   step = 0.05, group = grpShortRamp)

// -- Simple bucket mapping (the prompt's table; defaults = top of each range) --
grpSimpleBull = "Simple mapping: LT Bull targets"
sBullBull  = input.float(1.00, "Bull",         step = 0.05, group = grpSimpleBull)
sBullBullN = input.float(0.75, "Bull Neutral", step = 0.05, group = grpSimpleBull)
sBullBearN = input.float(0.50, "Bear Neutral", step = 0.05, group = grpSimpleBull)
sBullBear  = input.float(0.25, "Bear",         step = 0.05, group = grpSimpleBull)

grpSimpleBear = "Simple mapping: LT Bear targets (negative = short; inverse of Bull)"
sBearBull  = input.float(-0.25, "Bull",         step = 0.05, group = grpSimpleBear)
sBearBullN = input.float(-0.50, "Bull Neutral", step = 0.05, group = grpSimpleBear)
sBearBearN = input.float(-0.75, "Bear Neutral", step = 0.05, group = grpSimpleBear)
sBearBear  = input.float(-1.00, "Bear",         step = 0.05, group = grpSimpleBear)

// #############################################################################
// ############   SHARED ENGINE  (identical in indicator & strategy)   #########
// #############################################################################

// -----------------------------------------------------------------------------
// 1. CANDLE CLASSIFICATION  (LongTermStateEngine.GetCandleType)
//    return codes:  1 = Bull, -1 = Bear, 0 = Neutral
//        Bull  : current.Close > prev.High
//        Bear  : current.Close < prev.Low
//        else  : Neutral
// -----------------------------------------------------------------------------
f_classify(cl, prevHigh, prevLow) =>
    na(prevHigh) or na(prevLow) ? 0 : cl > prevHigh ? 1 : cl < prevLow ? -1 : 0

// -----------------------------------------------------------------------------
// 2. LONG TERM ENGINE  (LongTermStateEngine.Update)
//    LT state codes: 1 = Bull, 0 = Bear  (initial = Bear, matching C#)
//    Anchors trail the sequence (2nd-to-last candle). Neutral candles do
//    nothing except preserve the running sequences — exactly as in C#.
//    Returns: [state, bullCount, bearCount, bullAnchor, bearAnchor]
// -----------------------------------------------------------------------------
f_ltUpdate(candle, hi, lo, cl) =>
    var int   bullCount    = 0
    var int   bearCount    = 0
    var float bullAnchor   = na
    var float bearAnchor   = na
    var float lastBullLow  = na
    var float lastBearHigh = na
    var int   state        = 0            // 0 = Bear (LongTermState.Bear)

    if candle == 1
        // ---- BULL CANDLE ----
        bearCount := 0
        bullCount += 1
        // prior "last" bull low becomes the 2nd-to-last -> new anchor
        if bullCount >= 2
            bullAnchor := lastBullLow
        lastBullLow := lo
        // confirmation: transition to LT Bull
        if bullCount >= 2 and not na(bearAnchor) and cl > bearAnchor
            state := 1
    else if candle == -1
        // ---- BEAR CANDLE ----
        bullCount := 0
        bearCount += 1
        if bearCount >= 2
            bearAnchor := lastBearHigh
        lastBearHigh := hi
        // exit / bearish transition to LT Bear
        if bearCount >= 2 and not na(bullAnchor) and cl < bullAnchor
            state := 0
    // else NEUTRAL: preserve sequences, do nothing

    [state, bullCount, bearCount, bullAnchor, bearAnchor]

// -----------------------------------------------------------------------------
// 3. SHORT TERM ENGINE  (CandleStateEngine.Update)
//    ST state codes chosen to equal the C# bullishness StRank:
//        3 = Bull, 2 = BullNeutral, 1 = BearNeutral, 0 = Bear, na = null
//    Neutral candles do not affect counts or state.
//    Returns: [st, bullCount, bearCount]
// -----------------------------------------------------------------------------
f_stUpdate(candle) =>
    var int bullCount = 0
    var int bearCount = 0
    var int st        = na                // ShortTermState? currentState = null

    if candle == 1
        bullCount += 1
        bearCount := 0
        if bullCount >= 2
            st := 3                        // Bull
        else if st == 0                    // first Bull after a Bear sequence
            st := 1                        // BearNeutral
    else if candle == -1
        bearCount += 1
        bullCount := 0
        if bearCount >= 2
            st := 0                        // Bear
        else if st == 3                    // first Bear after a Bull sequence
            st := 2                        // BullNeutral
    // else NEUTRAL: no change

    [st, bullCount, bearCount]

// -----------------------------------------------------------------------------
// 4a. EXPOSURE HELPERS  (BankrollSimulator pure functions)
// -----------------------------------------------------------------------------
// StRank == the ST state code itself (3/2/1/0).
// AlignedRank: how aligned ST is with the trade direction.
//   LT Bull  -> bullishness (st)      ; LT Bear -> bearishness (3 - st)
f_alignedRank(lt, st) => lt == 1 ? st : 3 - st

// Long ramp level at a rung (clamped to [0,3]).
f_rampAt(rung) =>
    r = math.max(0, math.min(3, rung))
    r == 0 ? rampL0 : r == 1 ? rampL1 : r == 2 ? rampL2 : rampL3

// Short ramp level at a rung (clamped to [0,3]) — inverse of the long ramp.
f_shortRampAt(rung) =>
    r = math.max(0, math.min(3, rung))
    r == 0 ? sRampL0 : r == 1 ? sRampL1 : r == 2 ? sRampL2 : sRampL3

// ST exposure cap MAGNITUDE at a rung (clamped to [0,3]) for the given LT side.
// Bear caps are entered negative for clarity, so we return the absolute value.
f_stCapAt(lt, rung) =>
    r = math.max(0, math.min(3, rung))
    cap = lt == 1 ? (r == 0 ? stCapBull0 : r == 1 ? stCapBull1 : r == 2 ? stCapBull2 : stCapBull3)
       :            (r == 0 ? stCapBear0 : r == 1 ? stCapBear1 : r == 2 ? stCapBear2 : stCapBear3)
    math.abs(cap)

// -----------------------------------------------------------------------------
// 4b. FAITHFUL EXPOSURE ENGINE  (BankrollSimulator.Run, per-bar)
//    exposure = MIN(direction scale-in, ST-state cap). Long and short mirror.
//      * on LT change: reset (dir = LT, rampRung=0, cap=aligned)
//      * LT Bull: a confirming bull candle (bullRun>=2) climbs one long ramp rung
//      * LT Bear: a confirming bear candle (bearRun>=2) climbs one short ramp rung (inverse)
//      * ST cap steps ONE rung per ST-state change toward aligned rank
//    Guarded by `st != na`, mirroring the C# `if (st == null) continue;`
//    (run counters only advance once ST state exists).
//    Returns: [signedExposure, dir]   dir: 1 = long, -1 = short, 0 = flat
// -----------------------------------------------------------------------------
f_exposureFaithful(lt, st, candle) =>
    var int   bullRun   = 0
    var int   bearRun   = 0
    var int   rampRung  = 0
    var int   capRung   = 0
    var int   prevLt    = na
    var int   prevSt    = na
    var int   dir       = 0

    float signedExpo = na

    if not na(st) and not na(lt)
        // advance consecutive-run counters (neutral preserves both)
        if candle == 1
            bullRun += 1
            bearRun := 0
        else if candle == -1
            bearRun += 1
            bullRun := 0

        // -------- regime / scale-in --------
        if na(prevLt) or lt != prevLt
            dir       := lt == 1 ? 1 : -1
            rampRung  := 0
            capRung   := f_alignedRank(lt, st)
        else if lt == 1
            if candle == 1 and bullRun >= 2
                rampRung := rampRung + 1 > 3 ? 3 : rampRung + 1
        else
            if candle == -1 and bearRun >= 2
                rampRung := rampRung + 1 > 3 ? 3 : rampRung + 1

        // -------- ST cap: one rung per ST-state change --------
        if not na(prevLt) and lt == prevLt and not na(prevSt) and st != prevSt
            target = f_alignedRank(lt, st)
            if target > capRung
                capRung += 1
            else if target < capRung
                capRung -= 1

        scaleIn = lt == 1 ? f_rampAt(rampRung) : f_shortRampAt(rampRung)
        expo    = math.min(scaleIn, f_stCapAt(lt, capRung))
        signedExpo := (dir == 1 ? 1.0 : -1.0) * expo

        prevLt := lt
        prevSt := st

    [signedExpo, dir]

// -----------------------------------------------------------------------------
// 4c. SIMPLE BUCKET EXPOSURE (the prompt's mapping table; already signed)
// -----------------------------------------------------------------------------
f_exposureSimple(lt, st) =>
    na(lt) or na(st) ? na :
     lt == 1 ?
       (st == 3 ? sBullBull : st == 2 ? sBullBullN : st == 1 ? sBullBearN : sBullBear) :
       (st == 3 ? sBearBull : st == 2 ? sBearBullN : st == 1 ? sBearBearN : sBearBear)

// #############################################################################
// ############   END SHARED ENGINE                                    #########
// #############################################################################

// =============================================================================
// 5. RUN THE ENGINE ON THIS BAR
// =============================================================================
candle = f_classify(close, high[1], low[1])

[ltState, ltBullCount, ltBearCount, bullAnchor, bearAnchor] = f_ltUpdate(candle, high, low, close)
[stState, stBullCount, stBearCount]                         = f_stUpdate(candle)

[expFaithful, dirFaithful] = f_exposureFaithful(ltState, stState, candle)
expSimple                  = f_exposureSimple(ltState, stState)

signedExposure = exposureModel == MODEL_FAITHFUL ? expFaithful : expSimple

// =============================================================================
// 6. NAME HELPERS
// =============================================================================
f_ltName(lt)     => na(lt) ? "—" : lt == 1 ? "Bull" : "Bear"
f_stName(st)     => na(st) ? "—" : st == 3 ? "Bull" : st == 2 ? "Bull Neutral" : st == 1 ? "Bear Neutral" : "Bear"
f_candleName(c)  => c == 1 ? "Bull" : c == -1 ? "Bear" : "Neutral"

// =============================================================================
// 7. UI — CANDLE COLORING (by ST state)
// =============================================================================
barCol = na(stState) ? na :
         stState == 3 ? colBull :
         stState == 2 ? colBullN :
         stState == 1 ? colBearN : colBear
barcolor(barCol)

// =============================================================================
// 8. UI — BACKGROUND (by LT regime)
// =============================================================================
bg = ltState == 1 ? colBgBull : colBgBear
bgcolor(showBackground ? bg : na, title = "LT regime")

// =============================================================================
// 9. UI — ANCHORS
// =============================================================================
plot(showAnchors ? bullAnchor : na, "Bull Anchor", color = color.new(#26A69A, 0), style = plot.style_circles, linewidth = 2)
plot(showAnchors ? bearAnchor : na, "Bear Anchor", color = color.new(#F23645, 0), style = plot.style_circles, linewidth = 2)

// =============================================================================
// 10. UI — TABLE (top-right)
// =============================================================================
var table tbl = table.new(position.top_right, 2, 9, border_width = 1, frame_width = 1, frame_color = color.gray)

f_row(row, k, v, txtCol) =>
    table.cell(tbl, 0, row, k, text_color = color.gray,  text_halign = text.align_left,  text_size = size.small, bgcolor = color.new(color.black, 70))
    table.cell(tbl, 1, row, v, text_color = txtCol,      text_halign = text.align_right, text_size = size.small, bgcolor = color.new(color.black, 70))

if showTable and barstate.islast
    ltCol = ltState == 1 ? colBull : colBear
    stCol = na(stState) ? color.gray : stState == 3 ? colBull : stState == 2 ? colBullN : stState == 1 ? colBearN : colBear
    f_row(0, "LT State",       f_ltName(ltState), ltCol)
    f_row(1, "ST State",       f_stName(stState), stCol)
    f_row(2, "Target Exposure", na(signedExposure) ? "—" : str.tostring(signedExposure, "#.##"), na(signedExposure) ? color.gray : signedExposure >= 0 ? colBull : colBear)
    f_row(3, "Bull Count",     str.tostring(ltBullCount), color.white)
    f_row(4, "Bear Count",     str.tostring(ltBearCount), color.white)
    f_row(5, "Bull Anchor",    na(bullAnchor) ? "—" : str.tostring(bullAnchor, format.mintick), color.white)
    f_row(6, "Bear Anchor",    na(bearAnchor) ? "—" : str.tostring(bearAnchor, format.mintick), color.white)
    f_row(7, "Candle Type",    f_candleName(candle), candle == 1 ? colBull : candle == -1 ? colBear : color.gray)
    f_row(8, "Model",          exposureModel == MODEL_FAITHFUL ? "Ramp/Cap" : "Simple", color.gray)

// =============================================================================
// 11. DEBUG — bar-by-bar values for comparison against the C# engine.
//     Values are exposed in the Data Window (hover any bar) when Debug is on.
//     ST/LT plotted as their integer codes:  LT 1=Bull 0=Bear ;
//     ST 3=Bull 2=BullNeutral 1=BearNeutral 0=Bear ; Candle 1/-1/0.
// =============================================================================
plot(showDebug ? ltBullCount   : na, "DBG Bull Count",  display = display.data_window)
plot(showDebug ? ltBearCount   : na, "DBG Bear Count",  display = display.data_window)
plot(showDebug ? bullAnchor    : na, "DBG Bull Anchor", display = display.data_window)
plot(showDebug ? bearAnchor    : na, "DBG Bear Anchor", display = display.data_window)
plot(showDebug ? candle        : na, "DBG Candle Type", display = display.data_window)
plot(showDebug ? ltState       : na, "DBG LT State",    display = display.data_window)
plot(showDebug ? stState       : na, "DBG ST State",    display = display.data_window)
plot(showDebug ? signedExposure : na, "DBG Exposure",   display = display.data_window)
