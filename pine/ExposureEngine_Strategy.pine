// =============================================================================
// Exposure Engine — STRATEGY  (Pine Script v6)
// -----------------------------------------------------------------------------
// Uses the EXACT SAME engine as ExposureEngine_Indicator.pine (the section
// between the ##### banners is identical). This does NOT simulate options,
// premium, or leverage — it scales portfolio return by the target exposure,
// exactly like the C# BankrollSimulator:
//
//     dailyReturn  = (close - close[1]) / close[1]
//     tradeReturn  = position * dailyReturn            (signed: long +, short -)
//     bankroll    *= (1 + tradeReturn)
//
// Exposure model: each candle has one target from its (LT, ST) bucket; that
// target is EMA-smoothed, only rebalanced when it drifts past a band, then
// clamped to [min, max]. `position` is the result actually traded.
//
// Timing (no look-ahead, mirrors C#): the position decided on bar t is applied
// to the move from close[t] -> close[t+1]. Orders fill on close
// (process_orders_on_close=true) so the Strategy Tester equity matches this.
// The plotted "Synthetic equity" line is the exact C# mirror using
// position[1] * thisBarReturn.
// =============================================================================

//@version=6
strategy("Exposure Engine [Strategy]", overlay = true,
     default_qty_type = strategy.fixed, pyramiding = 100000,
     initial_capital = 10000, commission_type = strategy.commission.percent,
     commission_value = 0, slippage = 0, process_orders_on_close = true,
     calc_on_every_tick = false, max_labels_count = 500)

// =============================================================================
// 0. INPUTS
// =============================================================================
grpSim = "Simulation"
plotSynthetic = input.bool(true, "Plot synthetic exposure equity (exact C# mirror)", group = grpSim)
plotBuyHold   = input.bool(true, "Plot buy & hold reference",                        group = grpSim)
// Base capital comes from the Strategy properties dialog (strategy.initial_capital)
// so the synthetic curve and the Strategy Tester equity share the same base.

// -- Exposure model: one target per (LT, ST) bucket. Long positive, short negative.
grpBull = "Exposure — LT Bull (per ST state)"
bullBear  = input.float(-0.50, "ST Bear",         step = 0.05, group = grpBull)
bullBearN = input.float( 0.00, "ST Bear Neutral", step = 0.05, group = grpBull)
bullBullN = input.float( 0.50, "ST Bull Neutral", step = 0.05, group = grpBull)
bullBull  = input.float( 1.00, "ST Bull",         step = 0.05, group = grpBull)

grpBear = "Exposure — LT Bear (per ST state)"
bearBull  = input.float( 0.50, "ST Bull",         step = 0.05, group = grpBear)
bearBullN = input.float( 0.00, "ST Bull Neutral", step = 0.05, group = grpBear)
bearBearN = input.float(-0.50, "ST Bear Neutral", step = 0.05, group = grpBear)
bearBear  = input.float(-1.00, "ST Bear",         step = 0.05, group = grpBear)

// -- Smoothing & rebalance control
grpSmooth = "Smoothing & rebalance"
emaPeriod = input.int(5, "Exposure EMA period", minval = 1, group = grpSmooth,
     tooltip = "The per-candle target exposure is smoothed by this EMA before it is traded.")
biasPeriod = input.int(15, "Bias period", minval = 1, group = grpSmooth,
     tooltip = "Look-back for the dynamic long bias. The LT direction (+1 Bull, -1 Bear) is summed over this many candles. A window evenly split Bull/Bear gives 0; all-Bull gives +1, all-Bear -1.")
biasEmaPeriod = input.int(150, "Bias EMA period", minval = 1, group = grpSmooth,
     tooltip = "The dynamic bias is smoothed by this EMA before it skews the exposure EMA.")
driftPct  = input.float(30, "Rebalance drift (%)", minval = 0, step = 1, group = grpSmooth,
     tooltip = "Only move the position when it has drifted more than this many exposure-% from the EMA, then snap it back to the EMA. e.g. 20 with EMA 0.50 -> rebalance only if position < 0.30 or > 0.70.")
minExpPct = input.float(0, "Min exposure (%)", minval = -100, maxval = 100, step = 5, group = grpSmooth,
     tooltip = "Clamp on the POSITION only (not the per-candle target). -100 = fully short.")
maxExpPct = input.float(150,  "Max exposure (%)", minval = -100, maxval = 200, step = 5, group = grpSmooth,
     tooltip = "Clamp on the POSITION only (not the per-candle target). 100 = fully long; default 150 = 1.5x leverage on the strong-signal candles; ceiling 200.")

// -- Dynamic (per-candle) long bias: scale LongBias by z = z(HV) + z(persistence)
grpDyn = "Dynamic long bias"
dynBase  = input.float(1.0,  "LongBias at z = 0 (Base)", step = 0.5, group = grpDyn)
dynDecay = input.float(0.6,  "Exp decay (Exponential only)", step = 0.05, group = grpDyn)
dynMin   = input.float(0.0,  "LongBias min", step = 0.5, group = grpDyn)
dynMax   = input.float(150.0, "LongBias max", step = 0.5, group = grpDyn)
dynSmooth = input.int(10, "Bias smoothing (EMA bars)", minval = 1, group = grpDyn,
     tooltip = "EMA-smooth the per-candle LongBias so it does not whipsaw. 1 = off.")
biasSplit    = input.bool(true, "Split bias across LT dirs", group = grpDyn,
     tooltip = "Rolling sum: a Bull candle contributes 1 + bias/2 and a Bear candle -1 + bias/2 (instead of 1+bias / -1). The bias becomes a long tilt on BOTH sides, so a high-bias choppy name keeps conviction elevated through its LT-Bear stretches (a cleaner hold-through-chop). Broad-validated: Sharpe up in every HV bucket, edges buy&hold, ~flat drawdown. On by default.")
hvWindow      = input.int(60, "HV window (bars)", minval = 2, group = grpDyn)
persistWindow = input.int(63, "Persistence window (bars)", minval = 2, group = grpDyn)
hvRefMean   = input.float(57.0,   "HV ref mean",          group = grpDyn)
hvRefStd    = input.float(34.6,   "HV ref std",           group = grpDyn)
persRefMean = input.float(0.072, "Persistence ref mean", group = grpDyn)
persRefStd  = input.float(0.010, "Persistence ref std",  group = grpDyn)

// -- Out-of-region rule (mirrors BankrollSimulator.BearRegimeMode)
grpRegime = "Out-of-region rule"
bearRegimeMode = input.string("Cash", "Out-of-region mode", options = ["Cash", "Hold (buy & hold)", "Deploy strategy"], group = grpRegime,
     tooltip = "When the raw exposure signal is bearish -- the EMA of the (LT,ST) target exposure (before the bias skew) is < 0: Cash = flatten to 0 (default — rotate capital to an in-region name); Hold = force exposure 1 (mirror buy & hold); Deploy = keep running the strategy.")

grpRsi = "RSI position overlay"
rsiOverlayPeriod = input.int(2, "RSI overlay period (0 = off)", minval = 0, group = grpRsi,
     tooltip = "Overbought-trim overlay on the final position: position *= min(N / RSI(period), 1), N = numerator below — trims when overbought; does nothing when oversold (capped at 1, never levers up). 0 disables. Short period (2) validated best across four random-500 OOS samples; an ablation showed the trim is the entire edge, so it never levers.")
rsiMultNumerator = input.float(40, "RSI mult numerator N", minval = 1, group = grpRsi,
     tooltip = "The single trim knob. N in min(N/RSI, 1): trimming begins when RSI>N; at RSI=100 exposure -> N%. Default 40 = paired with the 1.5x max-exposure cap, the return/drawdown sweet spot on the momentum/flyer names while keeping strong upside participation. Lower N trims harder (more defensive); RSI overlay period 0 = off. This is the ONLY conditioning on the trim -- volume/ATR/exposure-shaping rules were removed for not helping the curated basket and the broad OOS sets simultaneously.")
posSmoothPeriod = input.int(5, "Final position smoothing (EMA bars, 0 = off)", minval = 0, group = grpRsi,
     tooltip = "EMA-smooth the FINAL traded position (after clamp, RSI trim, and the out-of-region rule) so RSI-2 single-bar chatter is averaged out. Cuts downside/drawdown by holding STEADIER (vs a lower N, which cuts it by holding less) so it preserves upside participation. Improves Sortino over the fixed-N baseline; benefit concentrates in the 50-100 HV band. 0 disables.")

// #############################################################################
// ############   SHARED ENGINE  (identical in indicator & strategy)   #########
// #############################################################################

// -----------------------------------------------------------------------------
// 1. CANDLE CLASSIFICATION  (LongTermStateEngine.GetCandleType)
//    return codes:  1 = Bull, -1 = Bear, 0 = Neutral
// -----------------------------------------------------------------------------
f_classify(cl, prevHigh, prevLow) =>
    na(prevHigh) or na(prevLow) ? 0 : cl > prevHigh ? 1 : cl < prevLow ? -1 : 0

// -----------------------------------------------------------------------------
// 2. LONG TERM ENGINE  (LongTermStateEngine.Update)
//    LT state codes: 1 = Bull, 0 = Bear  (initial = Bear).
//    Returns: [state, bullCount, bearCount, bullAnchor, bearAnchor]
// -----------------------------------------------------------------------------
f_ltUpdate(candle, hi, lo, cl) =>
    var int   bullCount    = 0
    var int   bearCount    = 0
    var float bullAnchor   = na
    var float bearAnchor   = na
    var float lastBullLow  = na
    var float lastBearHigh = na
    var int   state        = 0

    if candle == 1
        bearCount := 0
        bullCount += 1
        if bullCount >= 2
            bullAnchor := lastBullLow
        lastBullLow := lo
        if bullCount >= 2 and not na(bearAnchor) and cl > bearAnchor
            state := 1
    else if candle == -1
        bullCount := 0
        bearCount += 1
        if bearCount >= 2
            bearAnchor := lastBearHigh
        lastBearHigh := hi
        if bearCount >= 2 and not na(bullAnchor) and cl < bullAnchor
            state := 0

    [state, bullCount, bearCount, bullAnchor, bearAnchor]

// -----------------------------------------------------------------------------
// 3. SHORT TERM ENGINE  (CandleStateEngine.Update)
//    ST codes: 3=Bull 2=BullNeutral 1=BearNeutral 0=Bear na=null
//    Returns: [st, bullCount, bearCount]
// -----------------------------------------------------------------------------
f_stUpdate(candle) =>
    var int bullCount = 0
    var int bearCount = 0
    var int st        = na

    if candle == 1
        bullCount += 1
        bearCount := 0
        if bullCount >= 2
            st := 3
        else if st == 0
            st := 1
    else if candle == -1
        bearCount += 1
        bullCount := 0
        if bearCount >= 2
            st := 0
        else if st == 3
            st := 2

    [st, bullCount, bearCount]

// -----------------------------------------------------------------------------
// 4. TARGET EXPOSURE  (BankrollSimulator.TargetExposure)
//    One value per (LT, ST) bucket; already signed (short negative).
//    ST codes: 3=Bull 2=BullNeutral 1=BearNeutral 0=Bear
// -----------------------------------------------------------------------------
f_target(lt, st) =>
    na(lt) or na(st) ? na :
     lt == 1 ?
       (st == 3 ? bullBull : st == 2 ? bullBullN : st == 1 ? bullBearN : bullBear) :
       (st == 3 ? bearBull : st == 2 ? bearBullN : st == 1 ? bearBearN : bearBear)

// #############################################################################
// ############   END SHARED ENGINE                                    #########
// #############################################################################

// =============================================================================
// 5. RUN THE ENGINE ON THIS BAR
// =============================================================================
candle = f_classify(close, high[1], low[1])

[ltState, ltBullCount, ltBearCount, bullAnchor, bearAnchor] = f_ltUpdate(candle, high, low, close)
[stState, stBullCount, stBearCount]                         = f_stUpdate(candle)

target = f_target(ltState, stState)

// -----------------------------------------------------------------------------
// 5b. SMOOTH + REBALANCE
//     emaExp   : EMA of the per-candle target (same recurrence as the C# sim)
//     adjEma   : dynamic long-bias skew of the EMA  ->  |emaExp|*dynBiasEma + emaExp
//     held     : follows adjEma, but only re-sets when it drifts past the band
//     position : held, clamped to [min, max] — the exposure actually traded
// -----------------------------------------------------------------------------
alpha = 2.0 / (emaPeriod + 1)
var float emaExp = na
if not na(target)
    emaExp := na(emaExp) ? target : alpha * target + (1 - alpha) * emaExp

// Per-candle LongBias: fixed, or scaled by z = z(HV) + z(persistence) with FIXED refs
// (absolute scale): quiet name (z<0) -> large bias, hot name (z>0) -> small bias.
// Mirrors BankrollSimulator's DynamicLongBias.
hvRet  = na(close[1]) or close[1] <= 0 or close <= 0 ? na : math.log(close / close[1])
rollHv = ta.stdev(hvRet, hvWindow, false) * math.sqrt(252) * 100
zHv    = not na(rollHv) and hvRefStd > 0 ? (rollHv - hvRefMean) / hvRefStd : 0.0
netMove = math.abs(target - target[persistWindow])
pathLen = math.sum(math.abs(target - target[1]), persistWindow)
er      = pathLen > 1e-9 ? math.min(1.0, netMove / pathLen) : 1.0
zP      = not na(target[persistWindow]) and persRefStd > 0 ? (er - persRefMean) / persRefStd : 0.0
zTrait  = zHv + zP
dynLBraw = dynBase * math.exp(-dynDecay * zTrait)
dynLBc  = math.min(math.max(dynLBraw, dynMin), dynMax)
// EMA-smooth the per-candle bias over dynSmooth (C#-faithful, seeded on the first bar)
var float dynLbEma = na
dynLbEma := na(dynLbEma) ? dynLBc : (2.0 / (dynSmooth + 1)) * dynLBc + (1 - 2.0 / (dynSmooth + 1)) * dynLbEma
effLongBias = math.max(dynLbEma, dynMin)

// Dynamic long bias: rolling LT-direction sum over biasPeriod / biasPeriod.
// A Bull candle contributes (effLongBias + 1), a Bear candle -1; effLongBias skews
// the Bull weight (0 -> +1, -0.5 -> +0.5, +1 -> +2).
biasSig = biasSplit ? (ltState == 1 ? (1 + effLongBias / 2) : ltState == 0 ? (-1 + effLongBias / 2) : 0) : (ltState == 1 ? (effLongBias + 1) : ltState == 0 ? -1 : 0)
// C#-faithful sliding sum: add the current signal, drop the one leaving the window,
// divide by biasPeriod ALWAYS (partial early) — valid from bar 1, mirroring the C# Queue.
var float biasSum = 0.0
biasSum += biasSig
if bar_index >= biasPeriod
    biasSum -= biasSig[biasPeriod]
dynBias = biasSum / biasPeriod
// C#-faithful EMA seeded on the first bar. (ta.ema warms up ~biasEmaPeriod bars, leaving
// `position` na and the whole strategy dormant until then — with period 200 that skipped
// ~200 bars, re-anchoring the buy&hold and hiding the crash-protection window. C# seeds
// immediately, so we replicate that here.)
biasAlpha = 2.0 / (biasEmaPeriod + 1)
var float dynBiasEma = na
dynBiasEma := na(dynBiasEma) ? dynBias : biasAlpha * dynBias + (1 - biasAlpha) * dynBiasEma
// long-bias skew of the EMA: adjEma = |ema| * biasEma + ema  (mirrors C# BankrollSimulator)
adjEma = na(emaExp) ? na : math.abs(emaExp) * dynBiasEma + emaExp

driftBand = driftPct / 100.0
var float held = na
// Normal drift-band rebalance.
if not na(adjEma) and (na(held) or math.abs(held - adjEma) > driftBand)
    held := adjEma

loExp = math.min(minExpPct, maxExpPct) / 100.0
hiExp = math.max(minExpPct, maxExpPct) / 100.0
// Accurate full sizing: if the target saturates full, snap the follower to the clamp ceiling so we size to full
// (not stale-low, e.g. 0.7) despite the drift band. Correctness fix; OOS performance unchanged.
if not na(adjEma) and adjEma >= hiExp
    held := math.max(hiExp, math.max(hiExp - driftBand, adjEma - driftBand))
posClamped = na(held) ? na : math.min(math.max(held, loExp), hiExp)
// RSI overbought-trim overlay on the in-region position: *= min(N/RSI, 1) (trim when overbought only, never levers), before the out-of-region rule.
rsiVal = ta.rsi(close, math.max(rsiOverlayPeriod, 1))
rsiNumer = rsiMultNumerator
rsiPos = (rsiOverlayPeriod > 0 and not na(posClamped) and not na(rsiVal) and rsiVal > 0) ? math.min(math.max(posClamped * math.min(rsiNumer / rsiVal, 1.0), loExp), hiExp) : posClamped

// OUT-OF-REGION rule (mirrors BankrollSimulator.BearRegimeMode): out of region when the RAW exposure signal is
// bearish -- the EMA of the (LT,ST) target (emaExp, before the bias skew) is < 0. Parameter-free.
// regimeMode: 1 = Cash (flat), 2 = Hold (full long), 0 = Deploy (keep strategy).
regimeMode  = bearRegimeMode == "Cash" ? 1 : bearRegimeMode == "Hold (buy & hold)" ? 2 : 0
inRegion    = na(emaExp) or emaExp >= 0
outOfRegion = regimeMode != 0 and not na(emaExp) and emaExp < 0
rawPos = na(posClamped) ? na : (outOfRegion ? (regimeMode == 1 ? 0.0 : 1.0) : rsiPos)
// EMA-smooth the final position (matches BankrollSimulator.PositionSmoothPeriod)
var float posEma = na
posEma := (posSmoothPeriod > 0 and not na(rawPos)) ? (na(posEma) ? rawPos : (2.0 / (posSmoothPeriod + 1)) * rawPos + (1.0 - 2.0 / (posSmoothPeriod + 1)) * posEma) : rawPos
position = posEma

// =============================================================================
// 6. STRATEGY — size the position to the (smoothed, clamped) exposure.
//    Target notional = position * equity  =>  target contracts = that/close.
//    Rebalance to that target each confirmed bar (delta market order). With
//    process_orders_on_close, the fill is at this close and the exposure is
//    carried into the next bar's move — no look-ahead. The drift band means the
//    delta is usually zero (no order) — the position only moves when it must.
// =============================================================================
canTrade = barstate.isconfirmed and not na(position) and close > 0

targetContracts = canTrade ? position * strategy.equity / close : strategy.position_size
delta           = targetContracts - strategy.position_size

if canTrade and math.abs(delta) > 0
    if delta > 0
        strategy.order("rebalance+", strategy.long,  qty = delta)
    else
        strategy.order("rebalance-", strategy.short, qty = -delta)

// =============================================================================
// 7. SYNTHETIC EQUITY — exact C# BankrollSimulator mirror (for verification).
//    Uses the position from the previous bar applied to this bar's return
//    (no look-ahead), so it matches the Strategy Tester equity.
// =============================================================================
var float synthEquity = na
var float buyHold      = na
var float bhEntry      = na

r        = na(close[1]) or close[1] == 0 ? 0.0 : (close - close[1]) / close[1]
posPrev  = na(position[1]) ? 0.0 : position[1]
tradeRet = posPrev * r

synthEquity := na(synthEquity[1]) ? strategy.initial_capital : synthEquity[1] * (1 + tradeRet)

// buy & hold reference, anchored at the first bar with a valid exposure signal
if na(bhEntry) and not na(position)
    bhEntry := close
buyHold := na(bhEntry) ? strategy.initial_capital : strategy.initial_capital * (close / bhEntry)

plot(plotSynthetic ? synthEquity : na, "Synthetic equity", color = color.new(#2962FF, 0), linewidth = 2)
plot(plotBuyHold   ? buyHold     : na, "Buy & hold",       color = color.new(color.gray, 0), linewidth = 1)

// =============================================================================
// 7b. RECONCILIATION READOUT — the three equity numbers side by side.
//   * Synthetic  : the EXACT C# mirror (position[1] * return, compounded). This is
//                  what should equal the C# BankrollSimulator total return.
//   * Strategy   : the Strategy Tester's real order-executed net profit. Diverges from
//                  Synthetic due to whole-share sizing / no-margin rounding (usually
//                  leaves the position slightly UNDER-invested -> lower on big runners).
//   * Buy & hold : reference.
// If Synthetic ~= C# but Strategy is lower, the gap is order mechanics, not the engine.
// If Synthetic itself differs from C#, check inputs (stale on-chart values) or data feed.
// =============================================================================
synthRetPct = (synthEquity / strategy.initial_capital - 1.0) * 100.0
bhRetPct    = (buyHold     / strategy.initial_capital - 1.0) * 100.0
stratRetPct = strategy.netprofit / strategy.initial_capital * 100.0

var table recon = table.new(position.bottom_right, 2, 3, border_width = 1, frame_width = 1, frame_color = color.gray)
f_recon(row, k, v, col) =>
    table.cell(recon, 0, row, k, text_color = color.gray, text_halign = text.align_left,  text_size = size.small, bgcolor = color.new(color.black, 70))
    table.cell(recon, 1, row, v, text_color = col,        text_halign = text.align_right, text_size = size.small, bgcolor = color.new(color.black, 70))
if barstate.islast
    f_recon(0, "Synthetic (C# mirror)", str.tostring(synthRetPct, "#.#") + "%", synthRetPct >= 0 ? color.teal : color.red)
    f_recon(1, "Strategy (tester)",     str.tostring(stratRetPct, "#.#") + "%", stratRetPct >= 0 ? color.teal : color.red)
    f_recon(2, "Buy & hold",            str.tostring(bhRetPct,    "#.#") + "%", bhRetPct    >= 0 ? color.teal : color.red)

// =============================================================================
// 8. DEBUG — Data Window series for bar-by-bar comparison against C#.
// =============================================================================
plot(ltBullCount, "DBG Bull Count",  display = display.data_window)
plot(ltBearCount, "DBG Bear Count",  display = display.data_window)
plot(bullAnchor,  "DBG Bull Anchor", display = display.data_window)
plot(bearAnchor,  "DBG Bear Anchor", display = display.data_window)
plot(candle,      "DBG Candle Type", display = display.data_window)
plot(ltState,     "DBG LT State",    display = display.data_window)
plot(stState,     "DBG ST State",    display = display.data_window)
plot(target,      "DBG ST Value",  display = display.data_window)
plot(emaExp,      "DBG EMA",       display = display.data_window)
plot(adjEma,      "DBG Adj EMA",   display = display.data_window)
plot(position,    "DBG Exposure",  display = display.data_window)
plot(effLongBias, "DBG Dyn LongBias",  display = display.data_window)
plot(zTrait, "DBG z (HV+persist)", display = display.data_window)
